NODE_ENV=development
PORT=4000

# Keep the cluster URI here. Use MONGODB_DB_NAME to isolate this app's database.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<default-db>?retryWrites=true&w=majority&appName=<app>
MONGODB_DB_NAME=reading_almanac

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
COOKIE_NAME=reading_almanac_token
COOKIE_SECURE=false

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-first-boot
ADMIN_DISPLAY_NAME=Reader

VITE_KAVITA_DEFAULT_PASSWORD=

UPLOAD_DIR=uploads
PUBLIC_UPLOAD_PATH=/uploads
CLIENT_BUILD_DIR=client/dist
