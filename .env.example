NODE_ENV=development
PORT=4000

# Keep the cluster URI here. Use MONGODB_DB_NAME to isolate this app's database.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<default-db>?retryWrites=true&w=majority&appName=<app>
MONGODB_DB_NAME=reading_almanac

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-first-boot
ADMIN_DISPLAY_NAME=Reader

UPLOAD_DIR=uploads
PUBLIC_UPLOAD_PATH=/uploads
CLIENT_BUILD_DIR=client/dist

# Optional — Glitchtip/Sentry error tracking. Leave blank to disable.
# GLITCHTIP_DSN is read by the server at runtime (server/src/common/config/sentry.ts).
# VITE_GLITCHTIP_DSN is baked into the client bundle at Docker build time
# (docker-compose passes it through as a build arg — see client/Dockerfile) —
# a Sentry/Glitchtip DSN is meant to be public, safe to ship in the bundle.
GLITCHTIP_DSN=
VITE_GLITCHTIP_DSN=
